{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid",
        "roadmap": {
          ".validate": "newData.hasChildren(['version', 'items'])",
          "templateId": {
            ".validate": "newData.isString()"
          }
        },
        "meta": {
          "templateId": {
            ".validate": "newData.isString()"
          },
          "onboardingDone": {
            ".validate": "newData.isBoolean()"
          },
          "hiddenTemplateIds": {
            "$index": {
              ".validate": "newData.isString()"
            }
          }
        }
      }
    }
  }
}
