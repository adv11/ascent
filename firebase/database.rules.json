{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid",
        "roadmap": {
          ".validate": "newData.hasChildren(['version', 'items'])",
          "version": { ".validate": "newData.isNumber()" },
          "updatedAt": { ".validate": "newData.isNumber() || newData.val() === null" },
          "templateId": {
            ".validate": "newData.isString()"
          },
          "items": {
            "$itemId": {
              "title": { ".validate": "newData.isString() && newData.val().length <= 200" },
              "notes": { ".validate": "newData.isString() && newData.val().length <= 5000" },
              "resources": {
                "$index": {
                  "label": { ".validate": "newData.isString() && newData.val().length <= 120" },
                  "url": { ".validate": "newData.isString() && newData.val().length <= 2048" }
                }
              },
              "$other": {
                ".validate": "false"
              }
            }
          },
          "$other": {
            ".validate": "false"
          }
        },
        "roadmaps": {
          "$templateId": {
            ".validate": "newData.hasChildren(['version', 'items'])",
            "version": { ".validate": "newData.isNumber()" },
            "updatedAt": { ".validate": "newData.isNumber() || newData.val() === null" },
            "templateId": {
              ".validate": "newData.isString()"
            },
            "items": {
              "$itemId": {
                "title": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200" },
                "notes": { ".validate": "newData.isString() && newData.val().length <= 5000" },
                "phase": { ".validate": "newData.isString() && newData.val().length <= 200" },
                "section": { ".validate": "newData.isString() && newData.val().length <= 200" },
                "priority": { ".validate": "newData.val().matches(/^(P0|P1|P2|P3)$/)" },
                "done": { ".validate": "newData.isBoolean()" },
                "custom": { ".validate": "newData.isBoolean()" },
                "deleted": { ".validate": "newData.isBoolean()" },
                "createdAt": { ".validate": "newData.isNumber()" },
                "resources": {
                  "$index": {
                    ".validate": "$index.matches(/^[0-9]{1,2}$/)",
                    "label": { ".validate": "newData.isString() && newData.val().length <= 120" },
                    "url": { ".validate": "newData.isString() && newData.val().length <= 2048" }
                  }
                }
              }
            },
            "phases": {
              "$index": {
                ".validate": "$index.matches(/^[0-9]{1,3}$/)",
                "id": { ".validate": "newData.isString()" },
                "title": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200" },
                "priority": { ".validate": "newData.val().matches(/^(P0|P1|P2|P3)$/)" },
                "resourceKey": { ".validate": "newData.isString() || newData.val() === null" },
                "sections": {
                  "$sectionIndex": {
                    ".validate": "$sectionIndex.matches(/^[0-9]{1,3}$/)",
                    "id": { ".validate": "newData.isString()" },
                    "title": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200" }
                  }
                }
              }
            },
            "$other": {
              ".validate": "false"
            }
          }
        },
        "meta": {
          "templateId": {
            ".validate": "newData.isString()"
          },
          "activeTemplateId": {
            ".validate": "newData.isString()"
          },
          "startedTemplateIds": {
            "$index": {
              ".validate": "newData.isString()"
            }
          },
          "onboardingDone": {
            ".validate": "newData.isBoolean()"
          },
          "hiddenTemplateIds": {
            "$index": {
              ".validate": "newData.isString()"
            }
          },
          "customRoadmaps": {
            "$index": {
              ".validate": "newData.hasChildren(['id', 'title', 'createdAt']) && $index.matches(/^([0-9]|1[0-9]|2[0-4])$/)",
              "id": { ".validate": "newData.isString()" },
              "title": { ".validate": "newData.isString() && newData.val().length <= 200" },
              "description": { ".validate": "newData.isString() && newData.val().length <= 1000" },
              "createdAt": { ".validate": "newData.isNumber()" }
            }
          },
          "shareIds": {
            "$index": {
              ".validate": "newData.isString()"
            }
          },
          "favoriteRoadmapIds": {
            "$index": {
              ".validate": "newData.isString() && $index.matches(/^[0-2]$/)"
            }
          },
          "tourDone": {
            ".validate": "newData.isBoolean()"
          },
          "onboardingTourDone": {
            ".validate": "newData.isBoolean()"
          },
          "$other": {
            ".validate": "false"
          }
        },
        "dailyTodos": {
          "$todoId": {
            ".validate": "newData.hasChildren(['id', 'title', 'createdAt', 'expiresAt', 'done'])",
            "id": { ".validate": "newData.isString()" },
            "title": { ".validate": "newData.isString() && newData.val().length <= 200" },
            "createdAt": { ".validate": "newData.isNumber()" },
            "expiresAt": { ".validate": "newData.isNumber()" },
            "done": { ".validate": "newData.isBoolean()" },
            "doneAt": { ".validate": "newData.isNumber() || newData.val() === null" },
            "linkedTemplateId": { ".validate": "newData.isString() || newData.val() === null" },
            "linkedItemId": { ".validate": "newData.isString() || newData.val() === null" },
            "linkedItemTitle": { ".validate": "newData.isString() || newData.val() === null" },
            "$other": {
              ".validate": "false"
            }
          }
        },
        "activityLog": {
          "$date": {
            ".validate": "$date.matches(/^[0-9]{4}-[0-9]{2}-[0-9]{2}$/) && newData.isNumber() && newData.val() >= 0 && newData.val() <= 5000"
          }
        },
        "streakFreezes": {
          ".validate": "newData.hasChildren(['available'])",
          "available": { ".validate": "newData.isNumber() && newData.val() >= 0" },
          "usedDates": {
            "$index": {
              ".validate": "newData.isString()"
            }
          },
          "lastGrantedAt": { ".validate": "newData.isNumber() || newData.val() === null" },
          "$other": {
            ".validate": "false"
          }
        },
        "reports": {
          "$reportId": {
            ".write": "auth != null && auth.uid == $uid && !data.exists()",
            ".validate": "newData.hasChildren(['type','title','submittedAt']) && newData.child('type').val().matches(/^(bug|feature|feedback)$/) && newData.child('title').isString() && newData.child('title').val().length > 0 && newData.child('title').val().length <= 120",
            "type": { ".validate": "newData.val().matches(/^(bug|feature|feedback)$/)" },
            "title": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 120" },
            "submittedAt": { ".validate": "newData.isNumber()" },
            "severity": { ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 20)" },
            "description": { ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 2000)" },
            "steps": { ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 2000)" },
            "expected": { ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 2000)" },
            "actual": { ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 2000)" },
            "useCase": { ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 2000)" },
            "usageFreq": { ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 30)" },
            "screenshotOmitted": { ".validate": "newData.isBoolean()" },
            "metadata": { ".validate": "newData.val() === null || newData.hasChildren()" },
            "userId": { ".validate": "newData.val() === null || newData.isString()" },
            "isAnonymous": { ".validate": "newData.isBoolean()" },
            "status": { ".validate": "newData.isString() && newData.val().length <= 30" },
            "screenshotB64": { ".validate": "false" },
            "$other": {
              ".validate": "false"
            }
          }
        },
        "$other": {
          ".validate": "false"
        }
      }
    },
    "reports": {
      "$reportId": {
        ".read": "false",
        ".write": "auth != null && !data.exists()",
        ".validate": "newData.hasChildren(['type','title','submittedAt']) && newData.child('type').val().matches(/^(bug|feature|feedback)$/) && newData.child('title').isString() && newData.child('title').val().length > 0 && newData.child('title').val().length <= 120 && newData.child('userId').val() == auth.uid",
        "type": { ".validate": "newData.val().matches(/^(bug|feature|feedback)$/)" },
        "title": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 120" },
        "submittedAt": { ".validate": "newData.isNumber()" },
        "userId": { ".validate": "newData.isString()" },
        "severity": { ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 20)" },
        "description": { ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 2000)" },
        "steps": { ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 2000)" },
        "expected": { ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 2000)" },
        "actual": { ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 2000)" },
        "useCase": { ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 2000)" },
        "usageFreq": { ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 30)" },
        "screenshotOmitted": { ".validate": "newData.isBoolean()" },
        "metadata": { ".validate": "newData.val() === null || newData.hasChildren()" },
        "isAnonymous": { ".validate": "newData.isBoolean()" },
        "status": { ".validate": "newData.isString() && newData.val().length <= 30" },
        "screenshotB64": { ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 700000)" },
        "$other": {
          ".validate": "false"
        }
      }
    },
    "sharedRoadmaps": {
      "$shareId": {
        ".read": true,
        ".write": "auth != null && ((!data.exists() && newData.child('ownerUid').val() == auth.uid) || (data.exists() && data.child('ownerUid').val() == auth.uid && newData.val() === null))",
        ".validate": "newData.hasChildren(['schemaVersion', 'ownerUid', 'templateId', 'title', 'publishedAt', 'items'])",
        "schemaVersion": { ".validate": "newData.isNumber()" },
        "ownerUid": { ".validate": "newData.isString()" },
        "templateId": { ".validate": "newData.isString()" },
        "title": { ".validate": "newData.isString() && newData.val().length <= 200" },
        "publishedAt": { ".validate": "newData.isNumber()" },
        "items": {
          "$itemId": {
            ".validate": "newData.hasChildren(['title', 'phase', 'section', 'priority', 'done'])",
            "title": { ".validate": "newData.isString() && newData.val().length <= 200" },
            "phase": { ".validate": "newData.isString() && newData.val().length <= 200" },
            "section": { ".validate": "newData.isString() && newData.val().length <= 200" },
            "priority": { ".validate": "newData.isString() && newData.val().length <= 50" },
            "done": { ".validate": "newData.isBoolean()" },
            "resources": {
              "$index": {
                ".validate": "newData.hasChildren(['label', 'url']) && $index.matches(/^[0-9]{1,3}$/)",
                "label": { ".validate": "newData.isString() && newData.val().length <= 120" },
                "url": { ".validate": "newData.isString() && newData.val().length <= 2048" }
              }
            },
            "$other": { ".validate": "false" }
          }
        },
        "phases": {
          "$index": {
            ".validate": "$index.matches(/^[0-9]{1,2}$/)",
            "id": { ".validate": "newData.isString()" },
            "title": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200" },
            "priority": { ".validate": "newData.val().matches(/^(P0|P1|P2|P3)$/)" },
            "resourceKey": { ".validate": "newData.isString() || newData.val() === null" },
            "sections": {
              "$sectionIndex": {
                ".validate": "$sectionIndex.matches(/^[0-9]{1,2}$/)",
                "id": { ".validate": "newData.isString()" },
                "title": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200" }
              }
            }
          }
        },
        "$other": { ".validate": "false" }
      }
    }
  }
}
