{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "url": [
        "http://localhost:4173/"
      ],
      "settings": {
        "chromeFlags": "--no-sandbox --disable-setuid-sandbox --no-zygote --headless=new --disable-gpu --disable-dev-shm-usage",
        "maxWaitForFcp": 120000,
        "maxWaitForLoad": 150000
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.5 }],
        "interactive": ["error", { "maxNumericValue": 9000 }],
        "total-blocking-time": ["error", { "maxNumericValue": 600 }],
        "resource-summary:script:size": ["error", { "maxNumericValue": 900000 }],
        "resource-summary:total:size": ["warn", { "maxNumericValue": 1200000 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
