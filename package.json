{
  "name": "ascent",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "start": "node scripts/dev-server.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "generate:brand-assets": "node scripts/generate-brand-assets.mjs"
  },
  "description": "Ascent is a personal roadmap tracker for learning, revising, and tracking progress toward any goal.",
  "repository": {
    "type": "git",
    "url": "https://github.com/adv11/SwitchPrep.git"
  },
  "bugs": {
    "url": "https://github.com/adv11/SwitchPrep/issues"
  },
  "keywords": [
    "java",
    "spring-boot",
    "system-design",
    "genai",
    "roadmap",
    "firebase"
  ],
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "firebase-tools": "^15.24.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.9"
  }
}
